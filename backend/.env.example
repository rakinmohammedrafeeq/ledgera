# Ledgera Backend - Environment Variables Template

# Copy this file to .env.local or set these values in your deployment platform

# ============================================================
# Server Configuration
# ============================================================
# Port the application will listen on
# For cloud platforms (Render, Heroku), this may be auto-set
PORT=8080

# ============================================================
# Database Configuration (PostgreSQL)
# ============================================================
# Format: jdbc:postgresql://host:port/database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ledgera_db

# Database username
SPRING_DATASOURCE_USERNAME=postgres

# Database password (use strong password in production!)
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# PostgreSQL JDBC driver
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Connection pool settings (optional)
# SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5
# SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=1

# ============================================================
# JPA / Hibernate Configuration
# ============================================================
# DDL auto strategy: update, create, create-drop, validate, none
# For production, use 'validate' or 'none'
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Show SQL queries in logs (false for production)
SPRING_JPA_SHOW_SQL=false

# Hibernate dialect for PostgreSQL
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# Format SQL output (false for production)
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false

# ============================================================
# JWT Security Configuration
# ============================================================
# Secret key for JWT signing (must be 256+ bits)
# Generate with: openssl rand -base64 32
JWT_SECRET=Ledgera2024SecretKeyForJWTAuthenticationHS256AlgorithmRequiresAtLeast256BitsLong

# JWT token expiration time in milliseconds
# Default: 86400000 = 24 hours
# Common values:
#   3600000 = 1 hour
#   86400000 = 24 hours
#   604800000 = 7 days
JWT_EXPIRATION=86400000

# ============================================================
# Flyway Database Migration
# ============================================================
# Enable database migrations
SPRING_FLYWAY_ENABLED=true

# Location of migration scripts
SPRING_FLYWAY_LOCATIONS=classpath:db/migration

# Baseline on migrate (for existing databases)
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true

# ============================================================
# JVM Memory Configuration (Optional)
# ============================================================
# Set JVM heap size (optional, for memory-constrained environments)
# Examples:
#   256m = 256 megabytes
#   512m = 512 megabytes
#   1g = 1 gigabyte
# JAVA_OPTS=-Xmx256m -Xms128m

# ============================================================
# Logging Configuration (Optional)
# ============================================================
# Log level: TRACE, DEBUG, INFO, WARN, ERROR
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_LEDGERA=DEBUG
# LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO

# ============================================================
# Application Name (Optional)
# ============================================================
SPRING_APPLICATION_NAME=Ledgera

# ============================================================
# Notes
# ============================================================
#
# PRODUCTION CHECKLIST:
# ✓ Use strong, random password for SPRING_DATASOURCE_PASSWORD
# ✓ Generate new JWT_SECRET with: openssl rand -base64 32
# ✓ Set SPRING_JPA_HIBERNATE_DDL_AUTO=validate (not update)
# ✓ Set SPRING_JPA_SHOW_SQL=false
# ✓ Use environment-specific configuration
# ✓ Store sensitive values in secure vaults (not in Git)
# ✓ Use HTTPS in production
# ✓ Enable CORS headers if needed
#
# DEVELOPMENT vs PRODUCTION:
# Development:
#   SPRING_JPA_HIBERNATE_DDL_AUTO=update
#   SPRING_JPA_SHOW_SQL=true
#   LOGGING_LEVEL_ROOT=DEBUG
#
# Production:
#   SPRING_JPA_HIBERNATE_DDL_AUTO=validate
#   SPRING_JPA_SHOW_SQL=false
#   LOGGING_LEVEL_ROOT=INFO
#   Use managed database service
#
# CLOUD PLATFORM SETUP:
#
# Render.com:
#   1. Connect GitHub repo
#   2. Add these env vars in Render dashboard
#   3. PORT auto-set by Render (usually 10000)
#
# Heroku:
#   heroku config:set PORT=8080
#   heroku config:set SPRING_DATASOURCE_URL=...
#   etc.
#
# AWS:
#   Set in ECS Task Definition environment variables
#   Or use AWS Secrets Manager + ECS integration
#
# Docker Compose:
#   docker-compose.yml has defaults; override as needed
#

